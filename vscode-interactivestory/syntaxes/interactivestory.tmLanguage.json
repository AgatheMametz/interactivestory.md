{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "interactivestory",
  "scopeName": "source.interactivestory",
  "patterns": [
    {
      "begin": "\\A(---)\\s*\\n",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.yaml" }
      },
      "end": "^(---)\\s*$",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.yaml" }
      },
      "contentName": "meta.embedded.block.frontmatter",
      "patterns": [{ "include": "source.yaml" }]
    },
    {
      "begin": "^([\\t ]+)(?=\\S)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "punctuation.whitespace.interactivestory" }
      },
      "contentName": "meta.embedded.line.markdown.interactivestory",
      "patterns": [
        { "include": "#story-dsl" },
        { "include": "text.html.markdown" }
      ]
    },
    {
      "match": "^(?!^--$)([^\\s\\t#][^\\n]*)$",
      "name": "entity.name.tag.passage.interactivestory"
    },
    {
      "match": "^\\s+$",
      "name": "string.interactivestory.whitespace"
    }
  ],
  "repository": {
    "story-dsl": {
      "patterns": [
        { "include": "#story-set" },
        { "include": "#story-if-eq-binary" },
        { "include": "#story-if-link-binary" },
        { "include": "#story-once-link" },
        { "include": "#story-if-binary" },
        { "include": "#story-once-binary" },
        { "include": "#story-if-ternary" },
        { "include": "#story-once-keyword" },
        { "include": "#story-wait" },
        { "include": "#story-fx" },
        { "include": "#story-clear" },
        { "include": "#story-reset-variables" },
        { "include": "#story-goto" },
        { "include": "#story-glitch-span" },
        { "include": "#story-var-brace" },
        { "include": "#condition-expr" }
      ]
    },
    "condition-expr": {
      "patterns": [
        {
          "match": "\\s(&|\\|\\|)\\s|\\b(and|or)\\b",
          "name": "keyword.operator.logical.interactivestory"
        },
        {
          "match": "\\b(once)\\b",
          "captures": {
            "1": { "name": "support.function.interactivestory" }
          }
        },
        {
          "match": "([a-zA-Z_\\u00C0-\\u017F][a-zA-Z0-9_\\u00C0-\\u017F]*)\\s*(=|>=|<=|!=|<>|>|<)\\s*(\\S+)",
          "captures": {
            "1": { "name": "variable.other.interactivestory" },
            "2": { "name": "keyword.operator.comparison.interactivestory" },
            "3": { "name": "constant.language.interactivestory" }
          }
        }
      ]
    },
    "story-set": {
      "match": "(\\()(set:)(\\s*)([^)]+)(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "support.function.interactivestory" },
        "3": { "name": "" },
        "4": { "name": "string.unquoted.interactivestory" },
        "5": { "name": "punctuation.section.embedded.end.interactivestory" }
      }
    },
    "story-if-eq-binary": {
      "match": "(\\()((?:ifnot:|if:))(\\s*)(\\w+)(\\s*=\\s*)([^)]+)(\\))(\\s*)(\\()(\\[)([^\\]]*)(\\])(\\()([^)]*)(\\))(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "support.function.interactivestory" },
        "3": { "name": "" },
        "4": { "name": "variable.other.interactivestory" },
        "5": { "name": "keyword.operator.comparison.interactivestory" },
        "6": { "name": "constant.language.interactivestory" },
        "7": { "name": "punctuation.section.embedded.end.interactivestory" },
        "8": { "name": "" },
        "9": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "10": { "name": "punctuation.definition.link.interactivestory" },
        "11": { "name": "string.other.link.title.interactivestory" },
        "12": { "name": "punctuation.definition.link.interactivestory" },
        "13": { "name": "punctuation.definition.link.interactivestory" },
        "14": { "name": "markup.underline.link.interactivestory" },
        "15": { "name": "punctuation.definition.link.interactivestory" },
        "16": { "name": "punctuation.section.embedded.end.interactivestory" }
      }
    },
    "story-if-link-binary": {
      "match": "(\\()((?:ifnot:|if:))(\\s*)([^)]+)(\\))(\\s*)(\\[)([^\\]]*)(\\])(\\()([^)]*)(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "support.function.interactivestory" },
        "3": { "name": "" },
        "4": { "name": "meta.embedded.line.condition.interactivestory" },
        "5": { "name": "punctuation.section.embedded.end.interactivestory" },
        "6": { "name": "" },
        "7": { "name": "punctuation.definition.link.interactivestory" },
        "8": { "name": "string.other.link.title.interactivestory" },
        "9": { "name": "punctuation.definition.link.interactivestory" },
        "10": { "name": "punctuation.definition.link.interactivestory" },
        "11": { "name": "markup.underline.link.interactivestory" },
        "12": { "name": "punctuation.definition.link.interactivestory" }
      }
    },
    "story-once-link": {
      "match": "(?i)(\\()(once)(\\))(\\s*)(\\[)([^\\]]*)(\\])(\\()([^)]*)(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "support.function.interactivestory" },
        "3": { "name": "punctuation.section.embedded.end.interactivestory" },
        "4": { "name": "" },
        "5": { "name": "punctuation.definition.link.interactivestory" },
        "6": { "name": "string.other.link.title.interactivestory" },
        "7": { "name": "punctuation.definition.link.interactivestory" },
        "8": { "name": "punctuation.definition.link.interactivestory" },
        "9": { "name": "markup.underline.link.interactivestory" },
        "10": { "name": "punctuation.definition.link.interactivestory" }
      }
    },
    "story-if-binary": {
      "match": "(\\()((?:ifnot:|if:))(\\s*)([^)]+)(\\))(\\s*)(\\()",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "support.function.interactivestory" },
        "3": { "name": "" },
        "4": { "name": "meta.embedded.line.condition.interactivestory" },
        "5": { "name": "punctuation.section.embedded.end.interactivestory" },
        "6": { "name": "" },
        "7": { "name": "" }
      }
    },
    "story-once-binary": {
      "match": "(?i)(\\()(once)(\\))(\\s*)(\\()",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "support.function.interactivestory" },
        "3": { "name": "punctuation.section.embedded.end.interactivestory" },
        "4": { "name": "" },
        "5": { "name": "" }
      }
    },
    "story-if-ternary": {
      "match": "(\\()((?:ifnot:|if:))(\\s*)([^)]+)(\\))(?!\\s*\\()",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "support.function.interactivestory" },
        "3": { "name": "" },
        "4": { "name": "meta.embedded.line.condition.interactivestory" },
        "5": { "name": "punctuation.section.embedded.end.interactivestory" }
      }
    },
    "story-once-keyword": {
      "match": "(?i)(?<![(])\\b(once)\\b(?!\\))",
      "captures": {
        "1": { "name": "support.function.interactivestory" }
      }
    },
    "story-wait": {
      "match": "(?i)(\\()(\\s*)(wait:)(\\s*)(\\d+)(\\s*)(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "" },
        "3": { "name": "support.function.interactivestory" },
        "4": { "name": "" },
        "5": { "name": "constant.numeric.interactivestory" },
        "6": { "name": "" },
        "7": { "name": "punctuation.section.embedded.end.interactivestory" }
      }
    },
    "story-fx": {
      "match": "(?i)(\\()(\\s*)(fx:)(\\s*)([^)]+)(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "" },
        "3": { "name": "support.function.interactivestory" },
        "4": { "name": "" },
        "5": { "name": "string.unquoted.interactivestory" },
        "6": { "name": "punctuation.section.embedded.end.interactivestory" }
      }
    },
    "story-clear": {
      "match": "(?i)(\\()(\\s*)(clear)(\\s*)(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "" },
        "3": { "name": "support.function.interactivestory" },
        "4": { "name": "" },
        "5": { "name": "punctuation.section.embedded.end.interactivestory" }
      }
    },
    "story-reset-variables": {
      "match": "(?i)(\\()(\\s*)(reset_variables)(\\s*)(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "" },
        "3": { "name": "support.function.interactivestory" },
        "4": { "name": "" },
        "5": { "name": "punctuation.section.embedded.end.interactivestory" }
      }
    },
    "story-goto": {
      "match": "(?i)(\\()(\\s*)(goto:)(\\s*)([\\p{L}_][\\p{L}\\p{N}_]*)(\\s*)(\\))",
      "captures": {
        "1": { "name": "punctuation.section.embedded.begin.interactivestory" },
        "2": { "name": "" },
        "3": { "name": "support.function.interactivestory" },
        "4": { "name": "" },
        "5": { "name": "markup.underline.link.interactivestory" },
        "6": { "name": "" },
        "7": { "name": "punctuation.section.embedded.end.interactivestory" }
      }
    },
    "story-glitch-span": {
      "match": "(\\$)([^$]+)(\\$)",
      "captures": {
        "1": { "name": "punctuation.definition.glitch.begin.interactivestory" },
        "2": { "name": "markup.bold.glitch.interactivestory" },
        "3": { "name": "punctuation.definition.glitch.end.interactivestory" }
      }
    },
    "story-var-brace": {
      "match": "(\\{\\{)([\\p{L}_][\\p{L}\\p{N}_]*)(\\}\\})",
      "captures": {
        "1": { "name": "punctuation.definition.template.begin.interactivestory" },
        "2": { "name": "variable.other.interactivestory" },
        "3": { "name": "punctuation.definition.template.end.interactivestory" }
      }
    }
  }
}
