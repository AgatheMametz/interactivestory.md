{
  "name": "interactivestory-md",
  "displayName": "Interactive Story (.it)",
  "description": "Coloration pour les passages indentés (corps / options), le front matter YAML.",
  "version": "0.2.6",
  "publisher": "interactivestory",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgatheMametz/interactivestory.md"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "scripts": {
    "package": "npx --yes @vscode/vsce@latest package --no-dependencies --allow-missing-repository"
  },
  "contributes": {
    "configurationDefaults": {
      "[interactivestory]": {
        "editor.semanticHighlighting.enabled": false
      },
      "editor.tokenColorCustomizations": {
        "[interactivestory]": {
          "textMateRules": [
            {
              "scope": ["source.interactivestory support.function.interactivestory"],
              "settings": {
                "foreground": "#1565c0"
              }
            },
            {
              "scope": [
                "source.interactivestory markup.underline.link.interactivestory",
                "source.interactivestory string.other.link.title.interactivestory",
                "source.interactivestory punctuation.definition.link.interactivestory",
                "source.interactivestory markup.underline.link.markdown",
                "source.interactivestory string.other.link.title.markdown",
                "source.interactivestory string.other.link.description.markdown",
                "source.interactivestory string.other.link.description.title.markdown",
                "source.interactivestory punctuation.definition.link.markdown",
                "source.interactivestory punctuation.definition.link.description.begin.markdown",
                "source.interactivestory punctuation.definition.link.description.end.markdown",
                "source.interactivestory punctuation.definition.link.title.begin.markdown",
                "source.interactivestory punctuation.definition.link.title.end.markdown",
                "source.interactivestory meta.link.inline.markdown",
                "source.interactivestory meta.link.inet.markdown"
              ],
              "settings": {
                "foreground": "#e65100"
              }
            }
          ]
        }
      }
    },
    "languages": [
      {
        "id": "interactivestory",
        "aliases": ["Interactive Story", "interactivestory"],
        "extensions": [".it"],
        "configuration": "./language-configuration.json",
        "firstLine": "^---\\s*$"
      }
    ],
    "grammars": [
      {
        "language": "interactivestory",
        "scopeName": "source.interactivestory",
        "path": "./syntaxes/interactivestory.tmLanguage.json"
      }
    ]
  }
}
