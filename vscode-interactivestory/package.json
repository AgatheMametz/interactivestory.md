{
  "name": "interactivestory-md",
  "displayName": "Interactive Story (.it)",
  "description": "Coloration pour les passages indentés (corps / options), le front matter YAML.",
  "version": "0.3.11",
  "publisher": "interactivestory",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgatheMametz/interactivestory.md"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:interactivestory"],
  "scripts": {
    "package": "npx --yes @vscode/vsce@latest package --no-dependencies --allow-missing-repository",
    "install:cursor": "npm run package && cursor --install-extension ./interactivestory-md-$(node -p \"require('./package.json').version\").vsix --force"
  },
  "contributes": {
    "configurationDefaults": {
      "[interactivestory]": {
        "editor.semanticHighlighting.enabled": false
      },
      "editor.tokenColorCustomizations": {
        "[interactivestory]": {
          "textMateRules": [
            {
              "scope": [
                "entity.name.tag.passage.interactivestory",
                "source.interactivestory entity.name.tag.passage.interactivestory"
              ],
              "settings": {
                "foreground": "#FFB74D",
                "fontStyle": "bold"
              }
            },
            {
              "scope": [
                "support.function.interactivestory",
                "source.interactivestory support.function.interactivestory"
              ],
              "settings": {
                "foreground": "#64B5F6"
              }
            },
            {
              "scope": [
                "string.other.link.title.interactivestory",
                "string.other.link.title.markdown",
                "meta.link.inline.markdown"
              ],
              "settings": {
                "foreground": "#FFFFFF"
              }
            },
            {
              "scope": [
                "markup.underline.link.interactivestory",
                "punctuation.definition.link.interactivestory",
                "markup.underline.link.markdown"
              ],
              "settings": {
                "foreground": "#FFB74D"
              }
            },
            {
              "scope": ["markup.bold.glitch.interactivestory"],
              "settings": {
                "foreground": "#EF5350",
                "fontStyle": "italic"
              }
            },
            {
              "scope": ["variable.other.interactivestory"],
              "settings": {
                "foreground": "#81C784"
              }
            },
            {
              "scope": [
                "keyword.operator.comparison.interactivestory",
                "keyword.operator.logical.interactivestory"
              ],
              "settings": {
                "foreground": "#C586C0"
              }
            },
            {
              "scope": ["constant.language.interactivestory"],
              "settings": {
                "foreground": "#D7BA7D"
              }
            },
            {
              "scope": [
                "punctuation.section.embedded.begin.interactivestory",
                "punctuation.section.embedded.end.interactivestory"
              ],
              "settings": {
                "foreground": "#7EB6E8"
              }
            }
          ]
        }
      }
    },
    "languages": [
      {
        "id": "interactivestory",
        "aliases": ["Interactive Story", "interactivestory"],
        "extensions": [".it"],
        "configuration": "./language-configuration.json",
        "firstLine": "^---\\s*$"
      }
    ],
    "grammars": [
      {
        "language": "interactivestory",
        "scopeName": "source.interactivestory",
        "path": "./syntaxes/interactivestory.tmLanguage.json"
      }
    ]
  }
}
