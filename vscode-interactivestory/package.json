{
  "name": "interactivestory-md",
  "displayName": "Interactive Story (.it)",
  "description": "Coloration pour les passages indentés (corps / options), le front matter YAML.",
  "version": "0.2.3",
  "publisher": "interactivestory",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgatheMametz/interactivestory.md"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "scripts": {
    "package": "npx --yes @vscode/vsce@latest package --no-dependencies --allow-missing-repository"
  },
  "contributes": {
    "configurationDefaults": {
      "[interactivestory]": {
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": ["support.function.interactivestory"],
              "settings": {
                "foreground": "#e53935"
              }
            }
          ]
        }
      }
    },
    "languages": [
      {
        "id": "interactivestory",
        "aliases": ["Interactive Story", "interactivestory"],
        "extensions": [".it"],
        "configuration": "./language-configuration.json",
        "firstLine": "^---\\s*$"
      }
    ],
    "grammars": [
      {
        "language": "interactivestory",
        "scopeName": "source.interactivestory",
        "path": "./syntaxes/interactivestory.tmLanguage.json"
      }
    ]
  }
}
